{
  "name": "Order",
  "type": "object",
  "properties": {
    "plan_id": {
      "type": "string",
      "enum": [
        "pack_1",
        "pack_10",
        "pack_20",
        "monthly"
      ],
      "description": "Plan purchased"
    },
    "plan_label": {
      "type": "string"
    },
    "amount": {
      "type": "number",
      "description": "Amount paid in ILS"
    },
    "credits": {
      "type": "number",
      "description": "Number of ad credits granted (0 = unlimited monthly)"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "paypal",
        "bank_transfer"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "confirmed",
        "cancelled"
      ],
      "default": "pending"
    },
    "user_email": {
      "type": "string"
    },
    "user_name": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    },
    "valid_until": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "plan_id",
    "amount",
    "payment_method"
  ]
}